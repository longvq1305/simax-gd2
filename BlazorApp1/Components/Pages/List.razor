@using Microsoft.FluentUI.AspNetCore.Components
@using Blazored.LocalStorage
@using BlazorApp1.Models

@inject ILocalStorageService LocalStorage
@inject IDialogService DialogService

<FluentCard AreaRestricted="false">
    <FluentButton Color="white" Appearance="Appearance.Accent" OnClick="@OpenAddDialogAsync"
                  IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.AddCircle())" class="mb-3">
        Thêm mới
    </FluentButton>

    <FluentDataGrid Items="@itemsQueryable" RowStyle="@(item => "height: 60px;")" Pagination="@pagination"
                    TGridItem="Document">
        <TemplateColumn Title="#" Width="5%">
            @(GetRowIndex(context))
        </TemplateColumn>
        <TemplateColumn Title="Tên phân loại văn bản" Align="Align.Center">
            <a class="text-decoration-none" href="#">@context.Name</a>
        </TemplateColumn>
        <PropertyColumn Title="Tên viết tắt" Property="@(c => c.ShortName)" Align="Align.Center" />
        <PropertyColumn Title="Phân loại" Property="@(c => c.Category)" Align="Align.Center" />
        <TemplateColumn Title="Trạng thái" Align="Align.Center">
            <FluentBadge Appearance="Appearance.Accent">@context.Status</FluentBadge>
        </TemplateColumn>
        <TemplateColumn Title="Thao tác" Align="Align.Center" Width="10%">
            <FluentButton class="border"
                          IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Dismiss())"
                          OnClick="@(() => DeleteItem(context.Id))" Appearance="Appearance.Stealth" />
        </TemplateColumn>
    </FluentDataGrid>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="d-flex align-items-center gap-2">
            <span>Hiển thị</span>
            <FluentSelect Items="@(new[] { "2", "5", "10" })" @bind-Value="@SelectedItemsPerPage" Width="fit-content" />
            <span>bản ghi</span>
        </div>
        <FluentPaginator State="@pagination">
            <SummaryTemplate>
                Hiển thị @GetStartRecord() đến @GetEndRecord() của @(itemsQueryable?.Count() ?? 0) bản ghi
            </SummaryTemplate>
            <PaginationTextTemplate> Trang @(pagination.CurrentPageIndex + 1) / @(pagination.LastPageIndex + 1)
            </PaginationTextTemplate>
        </FluentPaginator>
    </div>
</FluentCard>

@code {
    PaginationState pagination = new PaginationState { ItemsPerPage = 2 };
    List<Document> documentList = new List<Document>();
    
    IQueryable<Document>? itemsQueryable;
    private const string StorageKey = "document_data";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedData = await LocalStorage.GetItemAsync<List<Document>>(StorageKey);
            if (savedData == null || !savedData.Any())
            {
                documentList = new List<Document>
                {
                    new() { Id = 1, Name = "Văn bản dự thảo của đơn vị", ShortName = "VBDTDV", Category = "Dự thảo", Status = "Mới" },
                    new() { Id = 2, Name = "Loại văn bản", ShortName = "LVB", Category = "Văn bản đến đơn vị", Status = "Mới" },
                    new() { Id = 3, Name = "Công điện", ShortName = "CĐ", Category = "Văn bản đến bộ", Status = "Mới" }
                };
                await LocalStorage.SetItemAsync(StorageKey, documentList);
            }
            else
            {
                documentList = savedData;
            }
            
            itemsQueryable = documentList.AsQueryable();
            StateHasChanged();
        }
    }

    public async Task FilterDataAsync(string keyword, string category)
    {
        var query = documentList.AsQueryable();

        if (!string.IsNullOrWhiteSpace(keyword))
        {
            query = query.Where(d =>
                (d.Name != null && d.Name.Contains(keyword, StringComparison.OrdinalIgnoreCase)) ||
                (d.ShortName != null && d.ShortName.Contains(keyword, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrEmpty(category))
        {
            query = query.Where(d => d.Category == category);
        }

        var filteredList = query.ToList();
        itemsQueryable = filteredList.AsQueryable();
        
        await pagination.SetCurrentPageIndexAsync(0);
        StateHasChanged();
    }

    public async Task ResetGridAsync()
    {
        itemsQueryable = documentList.AsQueryable();
        await pagination.SetCurrentPageIndexAsync(0);
        StateHasChanged();
    }

    private async Task DeleteItem(int id)
    {
        documentList.RemoveAll(x => x.Id == id);
        await LocalStorage.SetItemAsync(StorageKey, documentList);
        itemsQueryable = documentList.AsQueryable();
        StateHasChanged();
    }

    private string _selectedItemsPerPage = "2";
    private string SelectedItemsPerPage
    {
        get => _selectedItemsPerPage;
        set
        {
            if (_selectedItemsPerPage != value)
            {
                _selectedItemsPerPage = value;
                pagination.ItemsPerPage = int.Parse(value);
                pagination.SetCurrentPageIndexAsync(0);
            }
        }
    }
    
    private int GetStartRecord() => (itemsQueryable?.Count() ?? 0) > 0 ? (pagination.CurrentPageIndex * pagination.ItemsPerPage) + 1 : 0;
    
    private int GetEndRecord()
    {
        var end = (pagination.CurrentPageIndex + 1) * pagination.ItemsPerPage;
        var total = itemsQueryable?.Count() ?? 0;
        return end > total ? total : end;
    }
    
    private int GetRowIndex(Document doc)
    {
        return (itemsQueryable?.ToList().IndexOf(doc) ?? -1) + 1;
    }

    private async Task OpenAddDialogAsync()
    {
        Document newDocument = new() { Status = "Mới", Category = "Dự thảo" };
        var dialog = await DialogService.ShowDialogAsync<AddDocumentDialog>(newDocument, new DialogParameters()
        {
            Height =
"400px",
            Title = "Thêm mới văn bản",
            PrimaryAction = "Lưu",
            SecondaryAction = "Hủy"
        });
        var result = await dialog.Result;
        if (!result.Cancelled && result.Data != null)
        {
            var itemToAdd = (Document)result.Data;
            itemToAdd.Id = documentList.Any() ? documentList.Max(d => d.Id) + 1 : 1;
            documentList.Add(itemToAdd);
            await LocalStorage.SetItemAsync(StorageKey, documentList);
            await ResetGridAsync();
        }
    }
}